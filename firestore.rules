rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. USERS COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (userId == request.auth.uid || userId.matches('^custom_.*'));
      allow update: if isSignedIn() && (userId == request.auth.uid || userId.matches('^custom_.*') || incoming().buddies != null);
      allow delete: if isSignedIn() && (userId == request.auth.uid || userId.matches('^custom_.*'));
    }

    // 2. BUDDY REQUESTS COLLECTION
    match /buddy_requests/{requestId} {
      allow read, list: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isSignedIn() && request.auth.uid == incoming().fromId && (incoming().status == 'pending' || (incoming().status == 'accepted' && incoming().toId.matches('^custom_.*')));
      allow update: if isSignedIn() && (request.auth.uid == existing().toId || existing().toId.matches('^custom_.*')) && incoming().status in ['accepted', 'declined', 'pending'];
      allow delete: if isSignedIn() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid);
    }

    // 3. TRIPS COLLECTION
    match /trips/{tripId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == incoming().driverId;
      allow update: if isSignedIn() && (
        request.auth.uid == existing().driverId ||
        incoming().diff(existing()).affectedKeys().hasAny(['requests', 'passengers', 'liveLocations'])
      );
      allow delete: if isSignedIn() && request.auth.uid == existing().driverId;
    }

    // 4. FINANCES COLLECTION
    match /finances/{financeId} {
      allow read, list: if isSignedIn() && (resource.data.payerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && (incoming().receiverId == request.auth.uid || incoming().payerId == request.auth.uid);
      allow update: if isSignedIn() && (existing().receiverId == request.auth.uid || existing().payerId == request.auth.uid);
      allow delete: if isSignedIn() && (existing().receiverId == request.auth.uid || existing().payerId == request.auth.uid);
    }

    // 5. NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
      allow read, list: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && existing().recipientId == request.auth.uid;
      allow delete: if isSignedIn() && existing().recipientId == request.auth.uid;
    }
  }
}
