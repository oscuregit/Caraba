rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. USERS COLLECTION
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && (userId == request.auth.uid || userId.matches('^custom_.*'));
      allow update: if isSignedIn() && (userId == request.auth.uid || userId.matches('^custom_.*') || incoming().buddies != null);
      allow delete: if isSignedIn() && (userId == request.auth.uid || userId.matches('^custom_.*'));
    }

    // 2. BUDDY REQUESTS COLLECTION
    match /buddy_requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.auth.uid == incoming().fromId || incoming().fromId.matches('^custom_.*'));
      allow update: if isSignedIn() && (request.auth.uid == existing().toId || existing().toId.matches('^custom_.*'));
      allow delete: if isSignedIn() && (existing().fromId == request.auth.uid || existing().toId == request.auth.uid || existing().fromId.matches('^custom_.*'));
    }

    // 3. TRIPS COLLECTION
    match /trips/{tripId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.auth.uid == incoming().driverId || incoming().driverId.matches('^custom_.*'));
      allow update: if isSignedIn() && (
        request.auth.uid == existing().driverId ||
        existing().driverId.matches('^custom_.*') ||
        incoming().diff(existing()).affectedKeys().hasAny(['requests', 'passengers', 'liveLocations'])
      );
      allow delete: if isSignedIn() && (request.auth.uid == existing().driverId || existing().driverId.matches('^custom_.*'));
    }

    // 4. FINANCES COLLECTION
    match /finances/{financeId} {
      allow read: if true;
      allow create: if isSignedIn() && (incoming().receiverId == request.auth.uid || incoming().payerId == request.auth.uid || incoming().receiverId.matches('^custom_.*') || incoming().payerId.matches('^custom_.*'));
      allow update: if isSignedIn() && (existing().receiverId == request.auth.uid || existing().payerId == request.auth.uid || existing().receiverId.matches('^custom_.*') || existing().payerId.matches('^custom_.*'));
      allow delete: if isSignedIn() && (existing().receiverId == request.auth.uid || existing().payerId == request.auth.uid || existing().receiverId.matches('^custom_.*') || existing().payerId.matches('^custom_.*'));
    }

    // 5. NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (existing().recipientId == request.auth.uid || existing().recipientId.matches('^custom_.*'));
    }

    // 6. VEHICLES COLLECTION
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.auth.uid == incoming().userId || incoming().userId.matches('^custom_.*'));
      allow update, delete: if isSignedIn() && (request.auth.uid == existing().userId || existing().userId.matches('^custom_.*'));
    }
  }
}

